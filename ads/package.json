{
  "name": "adhdsat-ads",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion ad compositions for ADHDSat (isolated from the main app build)",
  "scripts": {
    "studio": "remotion studio",
    "render:hook": "remotion render HookVertical out/hook-15s.mp4",
    "render:explainer": "remotion render Explainer out/explainer-30s.mp4",
    "render:bumper": "remotion render Bumper out/bumper-6s.mp4",
    "render:all": "npm run render:hook && npm run render:explainer && npm run render:bumper"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.484",
    "@remotion/google-fonts": "^4.0.484",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "^4.0.484"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "typescript": "^5.9.3"
  }
}
