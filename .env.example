# Postgres connection string (Supabase transaction pooler, port 6543).
# Get it from: Supabase dashboard -> Connect -> Transaction pooler.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Optional: enables adaptive AI difficulty, AI insights, and Deep Dive
# explanations. Without it, the app uses rule-based fallbacks everywhere.
GEMINI_API_KEY=
